{
  "build": {
    "content": [
      {
        "files": ["**/*.{md,yml}"],
        "exclude": ["_site/**"]
      }
    ],
    "resource": [
      {
        "files": ["**/*.{png,jpg,jpeg,gif,svg,ico}"]
      }
    ],
    "output": "../_site/user",
    "template": ["default", "modern"],
    "globalMetadata": {
      "_appName": "K+B User Documentation",
      "_appTitle": "K+B User Documentation",
      "_enableSearch": true
    }
  }
}
